{
  "name": "@side/npm-dependency-stats-action",
  "version": "0.0.0-development",
  "description": "Github action for getting stats about npm dependencies",
  "author": "Side Inc.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.mjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "postinstall": "lefthook install",
    "build": "rimraf dist && node build.mjs",
    "check": "biome check --error-on-warnings",
    "check:fix": "biome check --write --error-on-warnings",
    "check:fix:staged": "biome check --write --error-on-warnings --staged --no-errors-on-unmatched",
    "lint": "biome lint --error-on-warnings",
    "lint:fix": "biome lint --write --error-on-warnings",
    "format": "biome format --write --error-on-warnings",
    "format:check": "biome format --error-on-warnings",
    "types:check": "tsc --noEmit",
    "test": "yarn types:check && vitest run",
    "test:cov": "yarn types:check && vitest run --coverage"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "21.0.0",
    "@side/commitlint-config": "1.1.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.12.3",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "lefthook": "2.1.6",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reside-eng/npm-dependency-stats-action.git"
  },
  "packageManager": "yarn@4.15.0",
  "private": true
}
